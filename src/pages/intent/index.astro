---
import "../../styles/global.css";
import intentPages from "../../data/intent-pages.js";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>Knitly Intent Pages | Invite-only social network for families and communities</title>
    <meta
      name="description"
      content="Explore intent pages for specific search queries around invite-only social networks, homeschool groups, church groups, and private community platforms."
    />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://knitly.io/intent/" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://knitly.io/intent/" />
    <meta property="og:title" content="Knitly Intent Pages | Invite-only social network for families and communities" />
    <meta property="og:description" content="Explore intent pages for specific search queries around invite-only social networks, homeschool groups, church groups, and private community platforms." />
    <meta property="og:image" content="https://knitly.io/og-image.jpg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Knitly Intent Pages | Invite-only social network for families and communities" />
    <meta name="twitter:description" content="Explore intent pages for specific search queries around invite-only social networks, homeschool groups, church groups, and private community platforms." />
    <meta name="twitter:image" content="https://knitly.io/og-image.jpg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=Nunito+Sans:ital,opsz,wght@0,6..12,300;0,6..12,400;0,6..12,500;0,6..12,600;0,6..12,700;1,6..12,300;1,6..12,400&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>

  <body class="min-h-screen bg-[#F7F5F3] text-[#2D2D2D] font-['Nunito_Sans'] overflow-x-hidden">
    <div class="noise-overlay"></div>

    <nav class="fixed top-0 left-0 right-0 z-50 bg-[#F7F5F3]/80 backdrop-blur-md">
      <div class="max-w-[1400px] mx-auto px-6 md:px-12 py-5 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 font-['Lora'] text-xl font-semibold tracking-tight text-[#E8594E]">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/></svg>
          Knitly
        </a>
        <a href="/" class="text-sm text-[#2D2D2D]/60 hover:text-[#2D2D2D]">Home</a>
      </div>
    </nav>

    <main class="max-w-[1100px] mx-auto px-6 md:px-12 pt-32 pb-24">
      <section class="reveal">
        <span class="font-['Nunito_Sans'] text-xs tracking-[0.3em] uppercase text-[#E8594E] font-semibold">Search-intent hubs</span>
        <h1 class="font-['Lora'] text-4xl md:text-6xl mt-4 leading-tight">
          Keyword pages for AI-answer mapping
        </h1>
        <p class="mt-5 text-base md:text-lg text-[#2D2D2D]/65 leading-relaxed max-w-3xl">
          Every high-intent query family should route to a distinct page with direct answers, practical examples, and clear FAQ schema for AI extractors.
        </p>
      </section>

      <section class="mt-10 grid md:grid-cols-2 gap-4">
        {intentPages.map((page) => (
          <article class="bg-white rounded-3xl border border-[#2D2D2D]/[0.08] p-6 md:p-8">
            <span class="font-['Nunito_Sans'] text-xs tracking-[0.2em] uppercase text-[#5B8FB9] font-semibold">
              {page.audience}
            </span>
            <h2 class="font-['Lora'] text-2xl mt-3 leading-snug">
              {page.title}
            </h2>
            <p class="mt-3 text-sm md:text-base text-[#2D2D2D]/65 leading-relaxed">
              {page.shortAnswer}
            </p>
            <a
              href={`/intent/${page.slug}`}
              class="inline-block mt-4 text-sm font-semibold text-[#E8594E] hover:text-[#C94B3E]"
            >
              Open intent page →
            </a>
          </article>
        ))}
      </section>
    </main>
  </body>
</html>
