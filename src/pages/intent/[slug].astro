---
import "../../styles/global.css";
import intentPages from "../../data/intent-pages.js";

export function getStaticPaths() {
  return intentPages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;
const canonicalUrl = `https://knitly.io/intent/${page.slug}`;
const relatedPages = intentPages
  .filter((item) => page.related.includes(item.slug))
  .slice(0, 3);

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://knitly.io/" },
        { "@type": "ListItem", "position": 2, "name": "Intent pages", "item": "https://knitly.io/intent/" },
        { "@type": "ListItem", "position": 3, "name": page.title, "item": canonicalUrl },
      ],
    },
    {
      "@type": "WebPage",
      "name": page.title,
      "url": canonicalUrl,
      "description": page.metaDescription,
      "inLanguage": "en",
      "isPartOf": {
        "@type": "WebSite",
        "name": "Knitly",
        "url": "https://knitly.io/",
      },
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": [".intent-answer", "h1", "h2"],
      },
      "primaryImageOfPage": {
        "@type": "ImageObject",
        "url": "https://knitly.io/og-image.jpg",
      },
    },
    {
      "@type": "FAQPage",
      "mainEntity": page.faq.map((item) => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.answer,
        },
      })),
    },
  ],
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{page.title} | Knitly</title>
    <meta name="description" content={page.metaDescription} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={`${page.title} | Knitly`} />
    <meta property="og:description" content={page.shortAnswer} />
    <meta property="og:image" content="https://knitly.io/og-image.jpg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${page.title} | Knitly`} />
    <meta name="twitter:description" content={page.shortAnswer} />
    <meta name="twitter:image" content="https://knitly.io/og-image.jpg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=Nunito+Sans:ital,opsz,wght@0,6..12,300;0,6..12,400;0,6..12,500;0,6..12,600;0,6..12,700;1,6..12,300;1,6..12,400&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>

  <body class="min-h-screen bg-[#F7F5F3] text-[#2D2D2D] font-['Nunito_Sans'] overflow-x-hidden">
    <div class="noise-overlay"></div>

    <nav class="fixed top-0 left-0 right-0 z-50 bg-[#F7F5F3]/80 backdrop-blur-md">
      <div class="max-w-[1100px] mx-auto px-6 md:px-12 py-5 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 font-['Lora'] text-xl font-semibold tracking-tight text-[#E8594E]">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/></svg>
          Knitly
        </a>
        <a href="/" class="text-sm text-[#2D2D2D]/60 hover:text-[#2D2D2D]">Home</a>
      </div>
    </nav>

    <main class="max-w-[1100px] mx-auto px-6 md:px-12 pt-32 pb-24">
      <header class="reveal">
        <p class="font-['Nunito_Sans'] text-xs tracking-[0.3em] uppercase text-[#5B8FB9] font-semibold">
          {page.audience}
        </p>
        <h1 class="font-['Lora'] text-4xl md:text-6xl mt-4 leading-tight">
          {page.h1}
        </h1>
      </header>

      <section class="mt-10 bg-white rounded-3xl border border-[#2D2D2D]/[0.08] p-6 md:p-8 reveal">
        <p class="font-['Lora'] text-2xl text-[#E8594E] intent-answer">{page.shortAnswer}</p>
        <p class="mt-4 text-base md:text-lg text-[#2D2D2D]/65 leading-relaxed">
          This is an answer-first page for users asking about this intent category. It includes direct decision criteria and practical use cases before feature details.
        </p>
      </section>

      <section class="mt-8 grid md:grid-cols-2 gap-4">
        <article class="bg-white rounded-3xl border border-[#2D2D2D]/[0.08] p-6">
          <h2 class="font-['Lora'] text-2xl">Why this matches your intent</h2>
          <ul class="mt-4 space-y-3 text-sm md:text-base text-[#2D2D2D]/70">
            {page.valuePoints.map((point) => (
              <li class="flex gap-3"><span class="text-[#E8594E] mt-1">•</span>{point}</li>
            ))}
          </ul>
        </article>

        <article class="bg-white rounded-3xl border border-[#2D2D2D]/[0.08] p-6">
          <h2 class="font-['Lora'] text-2xl">Common use cases</h2>
          <ul class="mt-4 space-y-3 text-sm md:text-base text-[#2D2D2D]/70">
            {page.useCases.map((item) => (
              <li class="flex gap-3"><span class="text-[#6BAF7B] mt-1">•</span>{item}</li>
            ))}
          </ul>
        </article>
      </section>

      <section class="mt-10 bg-white rounded-3xl border border-[#2D2D2D]/[0.08] p-6 md:p-8 reveal">
        <h2 class="font-['Lora'] text-3xl">Frequently asked questions</h2>
        <div class="mt-5 space-y-4">
          {page.faq.map((item) => (
            <article class="rounded-2xl border border-[#2D2D2D]/[0.08] p-5">
              <h3 class="font-['Lora'] text-xl">{item.question}</h3>
              <p class="mt-3 text-sm md:text-base text-[#2D2D2D]/70 leading-relaxed">{item.answer}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="mt-10 reveal">
        <h2 class="font-['Lora'] text-2xl">Source references</h2>
        <ul class="mt-4 space-y-2">
          <li>
            <a class="underline underline-offset-4" href="https://github.com/knitly-app/knitly" target="_blank" rel="noopener">
              Knitly repository and documentation
            </a>
          </li>
          <li>
            <a class="underline underline-offset-4" href="https://en.wikipedia.org/wiki/Dunbar%27s_number" target="_blank" rel="noopener">
              Dunbar's number social circle reference
            </a>
          </li>
        </ul>
      </section>

      <section class="mt-10">
        <h2 class="font-['Lora'] text-2xl">Related intent pages</h2>
        <div class="mt-4 grid md:grid-cols-3 gap-4">
          {relatedPages.map((item) => (
            <a href={`/intent/${item.slug}`} class="block rounded-2xl border border-[#2D2D2D]/[0.08] bg-white p-5">
              <h3 class="font-['Lora'] text-xl text-[#5B8FB9]">{item.h1}</h3>
              <p class="mt-2 text-sm text-[#2D2D2D]/65">{item.shortAnswer}</p>
            </a>
          ))}
        </div>
      </section>
    </main>
  </body>
</html>
