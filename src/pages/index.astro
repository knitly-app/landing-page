        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-[#E8594E]/[0.03] blur-[120px]"></div>
      </div>

      <div class="relative max-w-3xl mx-auto px-6 md:px-12 text-center reveal">
