---
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>Knitly — Invite-Only Social Network for Families, Communities, and Homeschool Groups</title>
    <meta name="description" content="Knitly is a self-hosted, invite-only social network for families, church groups, clubs, homeschool communities, and close groups. No ads. No algorithm. Your data stays yours." />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://knitly.io/" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://knitly.io/" />
    <meta property="og:site_name" content="Knitly" />
    <meta property="og:title" content="Knitly — Self-Hosted Social Network for Families & Communities" />
    <meta property="og:description" content="A self-hosted, invite-only social network for families, church groups, clubs, and homeschoolers. No algorithm. No ads. Your data stays yours." />
    <meta property="og:image" content="https://knitly.io/og-image.jpg" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Knitly — Self-Hosted Social Network for Families & Communities" />
    <meta name="twitter:description" content="A self-hosted, invite-only social network for families, church groups, clubs, and homeschoolers. No algorithm. No ads. Your data stays yours." />
    <meta name="twitter:image" content="https://knitly.io/og-image.jpg" />

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "SoftwareApplication",
            "name": "Knitly",
            "description": "Self-hosted, invite-only social network for families, churches, clubs, homeschoolers, and communities.",
            "applicationCategory": "SocialNetworkingApplication",
            "operatingSystem": "Cross-platform",
            "url": "https://knitly.io/",
            "offers": {
              "@type": "Offer",
              "price": "0",
              "priceCurrency": "USD",
              "priceSpecification": {
                "@type": "UnitPriceSpecification",
                "price": 0,
                "priceCurrency": "USD"
              }
            },
            "creator": {
              "@type": "Organization",
              "name": "Knitly",
              "url": "https://github.com/knitly-app/knitly"
            },
            "featureList": [
              "120 member cap for small social circles",
              "Invite-only membership controls",
              "Chronological activity feed",
              "Self-hosted deployments"
            ]
          },
          {
            "@type": "FAQPage",
            "mainEntity": [
              {
                "@type": "Question",
                "name": "Is Knitly an invite-only social app for families and friends?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Yes. Knitly is designed as an invite-only network with a 120-member cap, so it stays small and familiar."
                }
              },
              {
                "@type": "Question",
                "name": "Does Knitly offer a private social network for communities?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Yes. Knitly is built to be self-hosted and invite-managed, so membership, posts, and activity stay within your own server and group."
                }
              },
              {
                "@type": "Question",
                "name": "Can homeschool communities use a platform like this?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Yes. Homeschool groups can use invite-based circles, group chat, and poll features to coordinate routines without public algorithms."
                }
              }
            ]
          }
        ]
      }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=Nunito+Sans:ital,opsz,wght@0,6..12,300;0,6..12,400;0,6..12,500;0,6..12,600;0,6..12,700;1,6..12,300;1,6..12,400&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>

  <body class="min-h-screen bg-[#F7F5F3] text-[#2D2D2D] font-['Nunito_Sans'] overflow-x-hidden">

    <div class="noise-overlay"></div>

    <!-- Nav -->
    <nav class="fixed top-0 left-0 right-0 z-50 bg-[#F7F5F3]/80 backdrop-blur-md">
        <div class="max-w-[1400px] mx-auto px-6 md:px-12 py-5 flex items-center justify-between">
        <span class="flex items-center gap-2 font-['Lora'] text-xl font-semibold tracking-tight text-[#E8594E]">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/></svg>
          Knitly
        </span>
        <div class="flex items-center gap-6">
          <a href="/intent/" class="text-sm text-[#2D2D2D]/50 hover:text-[#2D2D2D] transition-colors">Intent Pages</a>
          <a href="#features" class="text-sm text-[#2D2D2D]/50 hover:text-[#2D2D2D] transition-colors">Features</a>
          <a href="#faq" class="text-sm text-[#2D2D2D]/50 hover:text-[#2D2D2D] transition-colors">FAQ</a>
          <a href="https://github.com/knitly-app/knitly" target="_blank" rel="noopener" class="flex items-center gap-2 text-sm font-semibold text-[#2D2D2D] hover:text-[#E8594E] transition-colors">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
            GitHub
          </a>
        </div>
      </div>
    </nav>

    <!-- ========== HERO ========== -->
    <section class="relative min-h-screen flex items-center pt-24 pb-16 md:pb-24">
      <div class="max-w-[1400px] mx-auto px-6 md:px-12 w-full">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-center">

          <div class="lg:col-span-5 reveal">
            <span class="font-['Nunito_Sans'] text-xs tracking-[0.3em] uppercase text-[#E8594E] font-semibold">For families, churches, clubs & homeschoolers</span>
            <h1 class="font-['Lora'] text-[clamp(2.6rem,6vw,5rem)] leading-[1.05] mt-4 tracking-tight">
              The best social network for close communities.
            </h1>
            <p class="mt-6 text-base md:text-lg text-[#2D2D2D]/60 leading-relaxed max-w-md">
              Knitly is an invite-only, self-hosted social network for families, church groups, clubs, homeschoolers, and local communities.
            </p>
            <p class="mt-6 text-base md:text-lg text-[#2D2D2D]/60 leading-relaxed max-w-md">
              A self-hosted, invite-only space for the people who matter most. No algorithm. No noise. Just real life, shared chronologically.
            </p>
            <div class="mt-8 flex items-center gap-4">
              <span class="inline-block w-2.5 h-2.5 rounded-full bg-[#6BAF7B]"></span>
              <span class="text-xs tracking-[0.2em] uppercase text-[#2D2D2D]/40 font-medium">120 members max</span>
            </div>
          </div>

          <!-- Moments Feed Mockup -->
          <div class="lg:col-span-7 reveal" style="--reveal-delay: 0.2s">
            <div class="relative">
              <!-- Decorative dot grid -->
              <div class="absolute -top-8 -right-4 w-32 h-32 opacity-[0.07]" aria-hidden="true" style="background-image: radial-gradient(circle, #E8594E 1px, transparent 1px); background-size: 12px 12px;"></div>

              <div class="app-mockup-frame lg:rotate-[-1.5deg] hover:rotate-0 transition-transform duration-700 ease-out bg-[#f9fafb]">
                <!-- App header bar -->
                <div class="flex items-center justify-between px-5 py-3.5 bg-white border-b border-gray-100">
                  <div class="flex items-center gap-3">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                      <rect x="2" y="4" width="16" height="2" rx="1" fill="#111827" opacity="0.2"/>
                      <rect x="2" y="9" width="12" height="2" rx="1" fill="#111827" opacity="0.2"/>
                      <rect x="2" y="14" width="16" height="2" rx="1" fill="#111827" opacity="0.2"/>
                    </svg>
                    <span class="font-bold text-sm text-gray-900">Moments</span>
                  </div>
                  <button class="bg-[#ef4444] text-white text-xs font-bold px-4 py-2 rounded-2xl flex items-center gap-1.5 shadow-sm">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5v14"/></svg>
                    New Moment
                  </button>
                </div>

                <!-- Post 1 -->
                <div class="mx-3 mt-3">
                  <div class="bg-white rounded-[2rem] p-6 shadow-sm border border-gray-50">
                    <div class="flex items-start gap-3.5 mb-4">
                      <div class="w-12 h-12 rounded-full bg-gradient-to-br from-[#FFB347] to-[#E8594E] flex items-center justify-center text-white text-sm font-bold border-2 border-white shadow-sm flex-shrink-0">S</div>
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center justify-between">
                          <div class="flex items-center gap-1.5">
                            <span class="font-bold text-gray-900">Sarah Chen</span>
                            <span class="text-gray-400 text-sm">@sarah</span>
                          </div>
                          <span class="text-xs text-gray-400">3h</span>
                        </div>
                      </div>
                    </div>
                    <p class="text-gray-800 text-base leading-relaxed mb-4">
                      The kids built a blanket fort in the living room and declared independence. They've written a constitution. Article 1: No bedtimes. <span class="text-[#ef4444] font-medium">@Marcus</span> they want you as Secretary of Snacks.
                    </p>
                    <!-- Photo -->
                    <div class="rounded-3xl overflow-hidden mb-4 -mx-2 aspect-[16/9] relative">
                      <img src="/image.webp" alt="A shared moment" class="w-full h-full object-cover" />
                    </div>
                    <!-- Action footer — matches PostCard: justify-between, border-t, Lucide icons -->
                    <div class="flex items-center justify-between pt-3 border-t border-gray-100">
                      <button class="flex items-center gap-2 p-2.5 rounded-xl text-[#ef4444] bg-red-50 transition-all">
                        <span class="text-lg leading-none">❤️</span>
                        <span class="text-sm font-medium">12</span>
                      </button>
                      <button class="flex items-center gap-2 p-2.5 rounded-xl text-gray-400 hover:text-blue-500 hover:bg-blue-50 transition-all">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
                        <span class="text-sm font-medium">4</span>
                      </button>
                      <button class="flex items-center gap-2 p-2.5 rounded-xl text-gray-400 hover:text-green-500 hover:bg-green-50 transition-all">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" x2="15.42" y1="13.51" y2="17.49"/><line x1="15.41" x2="8.59" y1="6.51" y2="10.49"/></svg>
                      </button>
                    </div>
                  </div>
                </div>

                <!-- Post 2 -->
                <div class="mx-3 mt-3">
                  <div class="bg-white rounded-[2rem] p-6 shadow-sm border border-gray-50">
                    <div class="flex items-start gap-3.5 mb-4">
                      <div class="w-12 h-12 rounded-full bg-gradient-to-br from-[#A8E6CF] to-[#5B8FB9] flex items-center justify-center text-white text-sm font-bold border-2 border-white shadow-sm flex-shrink-0">M</div>
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center justify-between">
                          <div class="flex items-center gap-1.5">
                            <span class="font-bold text-gray-900">Marcus</span>
                            <span class="text-gray-400 text-sm">@marcus</span>
                          </div>
                          <span class="text-xs text-gray-400">5h</span>
                        </div>
                      </div>
                    </div>
                    <p class="text-gray-800 text-base leading-relaxed mb-4">
                      Who's in for the Saturday hike? Thinking Table Rock again. <span class="text-[#ef4444] font-medium">@Sarah</span> <span class="text-[#ef4444] font-medium">@Dave</span> <span class="text-[#ef4444] font-medium">@Rachel</span>
                    </p>
                    <!-- Action footer -->
                    <div class="flex items-center justify-between pt-3 border-t border-gray-100">
                      <button class="flex items-center gap-2 p-2.5 rounded-xl text-gray-400 hover:text-[#ef4444] hover:bg-red-50 transition-all">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3.33.88-4.5 2.17A6.4 6.4 0 0 0 7.5 3 5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
                        <span class="text-sm font-medium">3</span>
                      </button>
                      <button class="flex items-center gap-2 p-2.5 rounded-xl text-gray-400 hover:text-blue-500 hover:bg-blue-50 transition-all">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
                        <span class="text-sm font-medium">2</span>
                      </button>
                      <button class="flex items-center gap-2 p-2.5 rounded-xl text-gray-400 hover:text-green-500 hover:bg-green-50 transition-all">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" x2="15.42" y1="13.51" y2="17.49"/><line x1="15.41" x2="8.59" y1="6.51" y2="10.49"/></svg>
                      </button>
                    </div>
                  </div>
                </div>

                <!-- Post 3 (partial, cut off) -->
                <div class="mx-3 mt-3 mb-3 opacity-50">
                  <div class="bg-white rounded-[2rem] p-6 pb-3 shadow-sm border border-gray-50">
                    <div class="flex items-start gap-3.5 mb-3">
                      <div class="w-12 h-12 rounded-full bg-gradient-to-br from-[#DDA0DD] to-[#9B59B6] flex items-center justify-center text-white text-sm font-bold border-2 border-white shadow-sm flex-shrink-0">R</div>
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center justify-between">
                          <div class="flex items-center gap-1.5">
                            <span class="font-bold text-gray-900">Rachel</span>
                            <span class="text-gray-400 text-sm">@rachel</span>
                          </div>
                          <span class="text-xs text-gray-400">1d</span>
                        </div>
                      </div>
                    </div>
                    <p class="text-gray-800 text-base leading-relaxed truncate">Movie night poll: Kids' pick or adults' pick this Friday...</p>
                  </div>
                </div>
              </div>

              <!-- Decorative editorial line -->
              <div class="absolute -bottom-6 -left-6 w-24 h-px bg-[#E8594E]/30 hidden lg:block" aria-hidden="true"></div>
              <div class="absolute -bottom-6 -left-6 w-px h-24 bg-[#E8594E]/30 hidden lg:block" aria-hidden="true"></div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ========== THE LIVING ROOM ========== -->
    <section class="py-24 md:py-40 relative overflow-hidden">
      <div class="absolute top-0 left-0 right-0 h-px bg-[#2D2D2D]/[0.06]"></div>

      <div class="max-w-[1400px] mx-auto px-6 md:px-12">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">

          <!-- Text -->
          <div class="lg:col-span-5 reveal">
            <span class="font-['Nunito_Sans'] text-xs tracking-[0.3em] uppercase text-[#5B8FB9] font-semibold">The Concept</span>
            <h2 class="font-['Lora'] text-4xl md:text-5xl lg:text-[3.5rem] mt-4 leading-[1.1]">
              Not a platform.<br/><em class="text-[#E8594E]">A living room.</em>
            </h2>
            <div class="w-16 h-px bg-[#E8594E]/40 mt-6 mb-6"></div>
            <p class="text-base md:text-lg text-[#2D2D2D]/60 leading-relaxed">
              Knitly is invite-only, capped at 120 members — Dunbar's number, the cognitive limit of meaningful relationships. No hashtags, no trending, no followers count. Every face is familiar. Every name is known.
            </p>
            <p class="mt-4 text-base text-[#2D2D2D]/50 leading-relaxed">
              Admin-controlled membership means you decide who's in the room. It's your community, run your way.
            </p>
            <div class="mt-8 grid grid-cols-3 gap-4">
              <div class="text-center">
                <span class="font-['Lora'] text-3xl font-semibold text-[#E8594E]">120</span>
                <span class="block text-[10px] tracking-[0.15em] uppercase text-[#2D2D2D]/40 mt-1">Max Members</span>
              </div>
              <div class="text-center">
                <span class="font-['Lora'] text-3xl font-semibold text-[#5B8FB9]">0</span>
                <span class="block text-[10px] tracking-[0.15em] uppercase text-[#2D2D2D]/40 mt-1">Algorithms</span>
              </div>
              <div class="text-center">
                <span class="font-['Lora'] text-3xl font-semibold text-[#6BAF7B]">100%</span>
                <span class="block text-[10px] tracking-[0.15em] uppercase text-[#2D2D2D]/40 mt-1">Yours</span>
              </div>
            </div>
          </div>

          <!-- Lobby Chat Mockup -->
          <div class="lg:col-span-6 lg:col-start-7 reveal" style="--reveal-delay: 0.15s">
            <div class="relative">
              <div class="absolute -top-6 -left-6 w-20 h-20 opacity-[0.05]" aria-hidden="true" style="background-image: radial-gradient(circle, #5B8FB9 1px, transparent 1px); background-size: 10px 10px;"></div>

              <div class="app-mockup-frame lg:rotate-[1deg] hover:rotate-0 transition-transform duration-700 ease-out">
                <!-- Lobby header -->
                <div class="px-5 py-3.5 border-b border-gray-100">
                  <div class="flex items-center gap-2">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
                    <span class="font-bold text-sm text-gray-900">The Lobby</span>
                  </div>
                  <span class="text-[10px] text-gray-400 ml-7">Chat with your people</span>
                </div>

                <!-- Chat messages -->
                <div class="px-5 py-4 space-y-5 min-h-[280px]">
                  <!-- Other person's message -->
                  <div class="flex gap-3">
                    <div class="w-8 h-8 rounded-full bg-gradient-to-br from-[#A8E6CF] to-[#5B8FB9] flex-shrink-0 flex items-center justify-center text-white text-[10px] font-bold">M</div>
                    <div class="flex flex-col items-start max-w-[70%]">
                      <div class="flex items-center gap-2">
                        <span class="text-sm font-medium text-gray-900">Marcus</span>
                        <span class="text-xs text-gray-400">@marcus</span>
                      </div>
                      <div class="mt-1 bg-gray-100 rounded-2xl rounded-tl-sm px-4 py-2">
                        <p class="text-sm">Anyone up for dinner at the park tonight? Weather looks amazing</p>
                      </div>
                      <span class="text-xs text-gray-400 mt-1">2m ago</span>
                    </div>
                  </div>

                  <!-- Other person's message -->
                  <div class="flex gap-3">
                    <div class="w-8 h-8 rounded-full bg-gradient-to-br from-[#DDA0DD] to-[#9B59B6] flex-shrink-0 flex items-center justify-center text-white text-[10px] font-bold">R</div>
                    <div class="flex flex-col items-start max-w-[70%]">
                      <div class="flex items-center gap-2">
                        <span class="text-sm font-medium text-gray-900">Rachel</span>
                        <span class="text-xs text-gray-400">@rachel</span>
                      </div>
                      <div class="mt-1 bg-gray-100 rounded-2xl rounded-tl-sm px-4 py-2">
                        <p class="text-sm">Yes! We'll bring the kids. Should I grab watermelon?</p>
                      </div>
                      <span class="text-xs text-gray-400 mt-1">1m ago</span>
                    </div>
                  </div>

                  <!-- Own message (right aligned, reversed) -->
                  <div class="flex gap-3 flex-row-reverse">
                    <div class="w-8 h-8 rounded-full bg-gradient-to-br from-[#FFB347] to-[#E8594E] flex-shrink-0 flex items-center justify-center text-white text-[10px] font-bold">Y</div>
                    <div class="flex flex-col items-end max-w-[70%]">
                      <div class="flex items-center gap-2 flex-row-reverse">
                        <span class="text-sm font-medium text-gray-900">You</span>
                        <span class="text-xs text-gray-400">@you</span>
                      </div>
                      <div class="mt-1 bg-[#ef4444] rounded-2xl rounded-tr-sm px-4 py-2">
                        <p class="text-sm text-white">Perfect! I'll bring the grill. See everyone at 6?</p>
                      </div>
                      <span class="text-xs text-gray-400 mt-1">just now</span>
                    </div>
                  </div>

                  <!-- Other person responding -->
                  <div class="flex gap-3">
                    <div class="w-8 h-8 rounded-full bg-gradient-to-br from-[#FFB347] to-[#E8594E] flex-shrink-0 flex items-center justify-center text-white text-[10px] font-bold">S</div>
                    <div class="flex flex-col items-start max-w-[70%]">
                      <div class="flex items-center gap-2">
                        <span class="text-sm font-medium text-gray-900">Sarah</span>
                        <span class="text-xs text-gray-400">@sarah</span>
                      </div>
                      <div class="mt-1 bg-gray-100 rounded-2xl rounded-tl-sm px-4 py-2">
